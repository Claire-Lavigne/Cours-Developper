    <div data-role="collapsible">
        <div data-role="trigger">
            <h2>Title 2</h2>
        </div>
    </div>
    <div data-role="content">Ceci est le conteu du 2ème bloc</div>
    <div data-role="collapsible">
        <div data-role="trigger">
            <h2>Title 3</h2>
        </div>
    </div>
    <div data-role="content">Ceci est le conteu du 3ème bloc</div>
</div>


// tabs

<div class="product data items"
     data-mage-init='{"mage/tabs": {
