</div>


// dropdowndialog

<div data-block="dropdown">
    <button type="button" class="action" data-trigger="triggerDropdown">
        <span data-bind="i18n: 'Click to open dropdown dialog'"></span>
    </button>
</div>
<div class="block"
     data-mage-init='{
        "dropdownDialog": {
            "appendTo": "[data-block=dropdown]",
            "triggerTarget":"[data-trigger=triggerDropdown]",
            "timeout": 2000,
            "closeOnMouseLeave": false,
            "closeOnEscape": true,
            "autoOpen": false,
            "triggerClass": "active",
            "parentClass": "active",
            "buttons": []
        }
     }'>
    <div>
        Here is our content
    </div>
</div>


